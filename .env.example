# Copy this file to .env.local for local development, or configure the same
# names in Vercel Environment Variables for deployed environments.
#
# Never commit real values for DATABASE_URL, BLOB_READ_WRITE_TOKEN,
# ADMIN_PASSWORD, or ADMIN_SESSION_SECRET.
# LOST_CLUE_WEBHOOK_URL is optional.
# NEXT_PUBLIC_API_URL is derived from API_URL in next.config.ts and usually
# does not need to be set manually.
# NEXT_PUBLIC_WECHAT_PAYMENT_QR_URL is derived from WECHAT_PAYMENT_QR_URL in
# next.config.ts and usually does not need to be set manually.
# NODE_ENV is provided by the runtime and does not need to be set manually.

API_URL=https://jingbantech.com
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token_example
WECHAT_PAYMENT_QR_URL=https://example.com/wechat-payment-qr.png
ADMIN_PASSWORD=change_me_admin_password
ADMIN_SESSION_SECRET=change_me_long_random_secret_at_least_32_chars
LOST_CLUE_WEBHOOK_URL=
